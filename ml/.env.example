# Numerai credentials are only required for submission uploads.
ML_NUMERAI_PUBLIC_ID=
ML_NUMERAI_SECRET_KEY=
ML_NUMERAI_MODEL_ID=

# Required for S3-backed local, SageMaker, and Modal workloads.
ML_S3_BUCKET=

# Required by the standalone SageMaker launcher.
AWS_REGION=
SAGEMAKER_ROLE_ARN=
SAGEMAKER_TRAINING_IMAGE=

# Optional operator settings.
AWS_PROFILE=
ML_JOB_PREFIX=numerai-dashboard
MODAL_APP_NAME=numerai-dashboard-ml
MODAL_AWS_SECRET_NAME=aws-credentials
MODAL_HF_SECRET_NAME=huggingface-credentials

# Required only by sagemaker/build_and_push.sh.
AWS_ACCOUNT_ID=
ECR_REPOSITORY=numerai-dashboard-ml-training
